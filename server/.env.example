# ==================================================================
# Claude via Azure AI Foundry (Anthropic native API)
# ==================================================================
AZURE_ANTHROPIC_API_KEY=YOUR_ROTATED_ANTHROPIC_KEY
AZURE_ANTHROPIC_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/anthropic/
AZURE_ANTHROPIC_MODEL_NAME=claude-opus-4-6-2

# ==================================================================
# Claude Haiku (fast model) via Azure AI Foundry
# ==================================================================
AZURE_ANTHROPIC_HAIKU_API_KEY=YOUR_ROTATED_ANTHROPIC_KEY
AZURE_ANTHROPIC_HAIKU_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/anthropic/
AZURE_ANTHROPIC_HAIKU_MODEL_NAME=claude-haiku-4-5

# ==================================================================
# Claude Sonnet (balanced model) via Azure AI Foundry
# ==================================================================
AZURE_ANTHROPIC_SONNET_API_KEY=YOUR_ROTATED_ANTHROPIC_KEY
AZURE_ANTHROPIC_SONNET_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/anthropic/
AZURE_ANTHROPIC_SONNET_MODEL_NAME=claude-sonnet-4-6

# ==================================================================
# SQL Server — Windows Integrated Authentication (msnodesqlv8)
# ==================================================================
# App runs as current Windows user; no DB_USER/DB_PASSWORD.
DB_SERVER=<sql-server-host>
DB_PORT=1433
DB_DATABASE=<database-name>
DB_TRUST_SERVER_CERT=true
# Optional: set to false if you get TLS/encryption errors
# DB_ENCRYPT=false
# Optional: ODBC driver name if default fails (e.g. "ODBC Driver 18 for SQL Server", "SQL Server Native Client 11.0")
# DB_DRIVER=ODBC Driver 17 for SQL Server

# ==================================================================
# Server
# ==================================================================
PORT=5000
ALLOWED_ORIGINS=http://localhost:5174

# ==================================================================
# Okta OAuth (Authorization Code + PKCE) — matches okta_implementation.md
# ==================================================================
OKTA_CLIENT_ID=<your-okta-client-id>
OKTA_REDIRECT_URI=https://localhost:5000/implicit/callback
OKTA_ISSUER_URL=https://<your-org>.okta.com/oauth2/<your-auth-server-id>
OKTA_CALLBACK_PATH=/implicit/callback

# Local HTTPS (required for Okta; generate cert with: npm run ssl:gen)
USE_HTTPS=true

# ==================================================================
# Session (required for auth)
# ==================================================================
SESSION_SECRET=<strong-random-string-for-cookie-signing>

# ==================================================================
# Azure Speech Services (voice-to-text)
# ==================================================================
AZURE_SPEECH_KEY=<your-azure-speech-subscription-key>
AZURE_SPEECH_REGION=eastus
