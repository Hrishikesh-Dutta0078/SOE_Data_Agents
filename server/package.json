{
  "name": "auto-agents-server",
  "version": "0.1.0",
  "description": "Fully autonomous agentic Text-to-SQL system — Express + LangGraph backend",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "cross-env NODE_ENV=development nodemon index.js",
    "test": "node --test",
    "test:security": "node --test tests/security/",
    "audit": "npm audit --audit-level=high",
    "ssl:gen": "node scripts/generate-ssl-cert.js",
    "harvest:schema": "node ../scripts/generateSchemaKnowledge.js",
    "harvest:values": "node ../scripts/harvestDistinctValues.js",
    "deploy:prepare": "node ../scripts/prepare-deploy.js",
    "validate:examples": "node ../scripts/validate-examples.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.2.13",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.0",
    "helmet": "^8.1.0",
    "msnodesqlv8": "^5.1.5",
    "mssql": "^11.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.9",
    "selfsigned": "^2.4.1"
  }
}
